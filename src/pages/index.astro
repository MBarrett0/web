---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import BeforeAfter from '../components/sims/BeforeAfter';
import WhatsAppShowcase from '../components/WhatsAppShowcase.astro';
import TurnosShowcase from '../components/TurnosShowcase.astro';
import Laptop3D from '../components/sims/Laptop3D';
import CaseStudy from '../components/CaseStudy.astro';
import Process from '../components/Process.astro';
import Plans from '../components/Plans.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
---
<Base
  title="Automatización, reservas y webs para tu negocio"
  description="Automatizo la atención, las reservas por WhatsApp y los turnos de tu negocio, y creo la página web que lo sostiene."
>
  <Header />
  <main>
    <Hero />
    <Services />
    <BeforeAfter client:visible={{ rootMargin: '600px' }} />
    <WhatsAppShowcase />
    <TurnosShowcase />
    <Laptop3D client:only="react" />
    <CaseStudy />
    <Process />
    <Plans />
    <FAQ />
    <Contact />
  </main>
  <Footer />
  <script>
    import { initReveals } from '../lib/reveal';
    initReveals();
  </script>
</Base>
