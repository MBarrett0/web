---
import SectionCta from './SectionCta.astro';

// Julio 2026: empieza miércoles (offset 2 celdas bajo L-M), 31 días, jueves 9 objetivo.
const monthOffset = 2;
const monthDays = Array.from({ length: 31 }, (_, i) => i + 1);
const slots = [
  { time: '10:30', kind: 'free' },
  { time: '12:00', kind: 'busy', who: 'Corte — Ana' },
  { time: '15:00', kind: 'free', target: true },
  { time: '16:30', kind: 'busy', who: 'Color — Lucía' },
  { time: '18:30', kind: 'free' },
];
---
<section id="whatsapp">
  <div class="container layout">
    <div class="side">
      <div class="section-head" data-reveal>
        <p class="kicker">Reservas por WhatsApp</p>
        <h2>El turno se agenda en la misma conversación.</h2>
        <p>Tu cliente escribe como siempre. El sistema responde al instante, ofrece horarios reales y confirma. Vos no tocás nada.</p>
      </div>
      <SectionCta question="¿Tus clientes ya te escriben por WhatsApp?" />
    </div>
    <div class="wa-duo" data-reveal>
      <div class="wa-phone" aria-label="Demostración de una reserva por WhatsApp">
        <div class="wa-top"><span class="wa-avatar"></span><span>Estética Nova</span><span class="wa-status">en línea</span></div>
        <div class="wa-chat">
          <p class="wa-msg user">¡Hola! ¿Tenés lugar el jueves?</p>
          <p class="wa-typing" aria-hidden="true"><span></span><span></span><span></span></p>
          <p class="wa-msg bot">¡Hola! Sí — el jueves tengo <strong>10:30</strong>, <strong>15:00</strong> y <strong>18:30</strong>. ¿Cuál te queda mejor?</p>
          <p class="wa-msg user">15:00 👌</p>
          <p class="wa-typing" aria-hidden="true"><span></span><span></span><span></span></p>
          <p class="wa-msg bot">¡Genial! ¿A nombre de quién agendo el turno?</p>
          <p class="wa-msg user">Camila Suárez</p>
          <p class="wa-typing" aria-hidden="true"><span></span><span></span><span></span></p>
          <p class="wa-msg bot card">✓ <strong>Turno confirmado</strong><br />Jueves · 15:00 · Camila Suárez<br /><small>Te llega un recordatorio el miércoles.</small></p>
        </div>
      </div>
      <div class="wa-cal" aria-label="Calendario de reservas, jueves 9 seleccionado">
        <div class="wa-cal-screens">
          <div class="wa-cal-month" aria-hidden="true">
            <p class="wa-cal-title">Julio</p>
            <div class="wa-cal-grid">
              {['L', 'M', 'M', 'J', 'V', 'S', 'D'].map((d) => <span class="dow">{d}</span>)}
              {Array.from({ length: monthOffset }).map(() => <span class="pad"></span>)}
              {monthDays.map((d) => <span class={`d${d === 9 ? ' target' : ''}`}>{d}</span>)}
            </div>
          </div>
          <div class="wa-cal-day">
            <p class="wa-cal-title">Jueves 9 · Julio</p>
            <ul class="wa-slots">
              {slots.map((s) => (
                <li class={`wa-slot ${s.kind}${s.target ? ' target booked' : ''}`}>
                  <span class="t">{s.time}</span>
                  {s.kind === 'busy' && <span class="who">{s.who}</span>}
                  {s.kind === 'free' && <span class="tag">libre</span>}
                  {s.target && <span class="wa-booking">✓ Camila Suárez</span>}
                </li>
              ))}
            </ul>
            <div class="wa-detail">
              <p class="wa-detail-name">Camila Suárez <span class="wa-detail-chip">Confirmado</span></p>
              <p class="wa-detail-meta">Jueves 9 de julio · 15:00</p>
              <p class="wa-detail-extra">Reservado por WhatsApp · Recordatorio: miércoles</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<script>
  import { gsap, ScrollTrigger, prefersReducedMotion } from '../lib/gsap';

  if (!prefersReducedMotion()) {
    const msgs = gsap.utils.toArray<HTMLElement>('#whatsapp .wa-chat .wa-msg');
    const typings = gsap.utils.toArray<HTMLElement>('#whatsapp .wa-typing');
    const calMonth = document.querySelector<HTMLElement>('#whatsapp .wa-cal-month')!;
    const calDay = document.querySelector<HTMLElement>('#whatsapp .wa-cal-day')!;
    const freeSlots = gsap.utils.toArray<HTMLElement>('#whatsapp .wa-slot.free');
    const targetSlot = document.querySelector<HTMLElement>('#whatsapp .wa-slot.target')!;
    const duo = document.querySelector<HTMLElement>('#whatsapp .wa-duo')!;
    const cal = document.querySelector<HTMLElement>('#whatsapp .wa-cal')!;
    const phone = document.querySelector<HTMLElement>('#whatsapp .wa-phone')!;
    const detail = document.querySelector<HTMLElement>('#whatsapp .wa-detail')!;
    let flyTl: gsap.core.Timeline | null = null;

    function cleanupFly() {
      flyTl?.kill();
      flyTl = null;
      duo.querySelector('.wa-fly')?.remove();
      gsap.set(targetSlot, { clearProps: 'backgroundColor,scale' });
    }

    function runMorph() {
      cleanupFly();
      const card = msgs[5];
      const from = card.getBoundingClientRect();
      const to = targetSlot.getBoundingClientRect();
      const base = duo.getBoundingClientRect();

      const clone = card.cloneNode(true) as HTMLElement;
      clone.classList.add('wa-fly');
      clone.setAttribute('aria-hidden', 'true');
      duo.appendChild(clone);
      gsap.set(clone, {
        position: 'absolute', margin: 0, zIndex: 5,
        left: from.left - base.left, top: from.top - base.top,
        width: from.width, height: from.height,
      });

      flyTl = gsap.timeline({ onComplete: cleanupFly });
      flyTl
        // trayecto + cambio de forma (FLIP manual)
        .to(clone, {
          left: to.left - base.left, top: to.top - base.top,
          width: to.width, height: to.height, borderRadius: '0.55rem',
          duration: 0.7, ease: 'power3.inOut',
        }, 0)
        // leve arco
        .to(clone, { y: -26, duration: 0.36, ease: 'power2.out' }, 0)
        .to(clone, { y: 0, duration: 0.34, ease: 'power2.in' }, 0.36)
        // aterrizaje: aparece la reserva real y el clon se desvanece, sin resaltado extra
        .add(() => targetSlot.classList.add('booked'), 0.7)
        .to(clone, { autoAlpha: 0, duration: 0.25 }, 0.7)
        // clic simulado sobre la reserva y tarjeta con los datos del turno
        .to(targetSlot, { scale: 0.96, duration: 0.12, ease: 'power2.in' }, 1.6)
        .to(targetSlot, { scale: 1, duration: 0.18, ease: 'power2.out', clearProps: 'scale' }, 1.72)
        .fromTo(detail,
          { autoAlpha: 0, scale: 0.9, y: 6 },
          { autoAlpha: 1, scale: 1, y: 0, duration: 0.45, ease: 'back.out(1.6)' },
          1.95);
    }

    gsap.set(msgs, { autoAlpha: 0, y: 14 });
    gsap.set(typings, { autoAlpha: 0 });
    gsap.set(calMonth, { autoAlpha: 1, xPercent: 0 });
    gsap.set(calDay, { autoAlpha: 0, xPercent: 10 });
    // el calendario arranca escondido detrás del teléfono; se desliza recto por un solo eje
    const calRect = cal.getBoundingClientRect();
    const phoneRect = phone.getBoundingClientRect();
    const isRow = calRect.left > phoneRect.left + phoneRect.width / 2;
    gsap.set(cal, {
      x: isRow ? phoneRect.left - calRect.left : 0,
      y: isRow ? 0 : phoneRect.top - calRect.top,
      autoAlpha: 0,
    });

    function resetSim() {
      cleanupFly();
      targetSlot.classList.remove('booked');
      gsap.set(detail, { autoAlpha: 0 });
    }
    resetSim();

    const tl = gsap.timeline({ paused: true, defaults: { ease: 'power2.out' } });
    tl.to(msgs[0], { autoAlpha: 1, y: 0, duration: 0.5 }, 0.4)
      // recién con la pregunta del jueves, el calendario se desliza desde atrás del teléfono
      .to(cal, { x: 0, y: 0, autoAlpha: 1, duration: 0.9, ease: 'power3.out' }, '+=0.5')
      .to(typings[0], { autoAlpha: 1, duration: 0.25 }, '+=0.4')
      // el calendario reacciona mientras el bot "escribe"
      .to(calMonth, { xPercent: -10, autoAlpha: 0, duration: 0.45, ease: 'power2.in' }, '+=0.5')
      .to(calDay, { xPercent: 0, autoAlpha: 1, duration: 0.5 }, '-=0.1')
      // los horarios libres se encienden escalonados y se apagan todos juntos
      .to(freeSlots, {
        backgroundColor: 'rgba(37, 211, 102, 0.28)',
        duration: 0.35, stagger: 0.3,
      }, '+=0.35')
      .to(freeSlots, {
        backgroundColor: 'rgba(37, 211, 102, 0)',
        duration: 0.5, clearProps: 'backgroundColor',
      }, '+=0.75')
      .to(typings[0], { autoAlpha: 0, duration: 0.25 }, '<')
      .to(msgs[1], { autoAlpha: 1, y: 0, duration: 0.5 }, '<')
      .to(msgs[2], { autoAlpha: 1, y: 0, duration: 0.5 }, '+=1.3')
      // el bot pide los datos y el cliente responde con su nombre
      .to(typings[1], { autoAlpha: 1, duration: 0.25 }, '+=0.5')
      .to(typings[1], { autoAlpha: 0, duration: 0.25 }, '+=1.1')
      .to(msgs[3], { autoAlpha: 1, y: 0, duration: 0.5 }, '<')
      .to(msgs[4], { autoAlpha: 1, y: 0, duration: 0.5 }, '+=1.2')
      .to(typings[2], { autoAlpha: 1, duration: 0.25 }, '+=0.5')
      .to(typings[2], { autoAlpha: 0, duration: 0.25 }, '+=1.1')
      .to(msgs[5], { autoAlpha: 1, y: 0, duration: 0.5 }, '<')
      .add(() => runMorph(), '+=0.6');

    ScrollTrigger.create({
      trigger: '#whatsapp .wa-phone',
      start: 'top 70%',
      onEnter: () => { resetSim(); tl.restart(); },
      onEnterBack: () => { resetSim(); tl.restart(); },
    });
  }
</script>
<style>
  .layout { display: flex; gap: clamp(2rem, 5vw, 4rem); align-items: center; flex-wrap: wrap; }
  .side { flex: 1 1 20rem; }
  .wa-duo {
    flex: 1 1 30rem; display: flex; gap: clamp(1rem, 2.5vw, 1.8rem);
    align-items: center; justify-content: center; flex-wrap: nowrap;
    position: relative; /* host del clon viajero */
  }
  /* solo en pantallas angostas el calendario baja debajo del teléfono */
  @media (max-width: 40rem) { .wa-duo { flex-wrap: wrap; } }
  .wa-phone {
    flex: 0 1 21rem;
    background: #0b141a; border: 1px solid var(--line); border-radius: 1.6rem;
    overflow: hidden; box-shadow: 0 30px 60px rgb(0 0 0 / 0.45);
    width: min(21rem, 100%);
    min-width: 0;
    position: relative; z-index: 2; /* el calendario se desliza por detrás */
  }
  .wa-top {
    display: flex; align-items: center; gap: 0.6rem;
    background: #1f2c33; padding: 0.8rem 1rem; font-weight: 600; font-size: 0.95rem;
  }
  .wa-avatar { width: 1.9rem; height: 1.9rem; border-radius: 50%; background: linear-gradient(135deg, var(--accent), var(--accent-2)); }
  .wa-status { margin-left: auto; font-weight: 400; font-size: 0.75rem; color: #8fa6ae; }
  .wa-chat { padding: 1.1rem 0.9rem 1.4rem; display: flex; flex-direction: column; gap: 0.6rem; min-height: 21rem; }
  .wa-msg { max-width: 85%; padding: 0.55rem 0.8rem; border-radius: 0.7rem; font-size: 0.92rem; line-height: 1.4; }
  .wa-msg.user { align-self: flex-end; background: #005c4b; border-bottom-right-radius: 0.15rem; }
  .wa-msg.bot { align-self: flex-start; background: #1f2c33; border-bottom-left-radius: 0.15rem; }
  .wa-msg.card { border: 1px solid #2a3942; }
  .wa-msg small { color: #8fa6ae; }
  .wa-typing { align-self: flex-start; background: #1f2c33; border-radius: 0.7rem; padding: 0.6rem 0.8rem; display: flex; gap: 0.25rem; }
  .wa-typing span { width: 0.4rem; height: 0.4rem; border-radius: 50%; background: #8fa6ae; animation: blink 1.2s infinite; }
  .wa-typing span:nth-child(2) { animation-delay: 0.2s; }
  .wa-typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes blink { 0%, 60%, 100% { opacity: 0.3; } 30% { opacity: 1; } }
  /* Calendario */
  .wa-cal {
    flex: 0 1 15.5rem; width: min(15.5rem, 100%);
    background: #0b141a; border: 1px solid var(--line); border-radius: 1.2rem;
    box-shadow: 0 30px 60px rgb(0 0 0 / 0.45);
    padding: 1rem 0.9rem 1.1rem;
    min-width: 0;
    position: relative; z-index: 1;
  }
  .wa-cal-screens { position: relative; }
  .wa-cal-day { position: relative; }
  .wa-cal-title { font-weight: 600; font-size: 0.9rem; margin-bottom: 0.7rem; }
  /* Estado final por defecto (no-JS / reduced motion): Mes oculto, Día visible */
  .wa-cal-month { position: absolute; inset: 0; opacity: 0; visibility: hidden; }
  .wa-cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 0.25rem; text-align: center; font-size: 0.72rem; }
  .wa-cal-grid .dow { color: #8fa6ae; font-weight: 600; padding-block: 0.15rem; }
  .wa-cal-grid .d { padding-block: 0.3rem; border-radius: 0.4rem; color: #d5dee3; }
  .wa-cal-grid .d.target { background: rgba(37, 211, 102, 0.16); border: 1px solid rgba(37, 211, 102, 0.45); font-weight: 700; }
  .wa-slots { list-style: none; display: flex; flex-direction: column; gap: 0.45rem; padding: 0; margin: 0; }
  .wa-slot {
    display: flex; align-items: center; gap: 0.55rem;
    background: #141f26; border: 1px solid var(--line); border-radius: 0.55rem;
    padding: 0.45rem 0.65rem; font-size: 0.82rem;
  }
  .wa-slot .t { font-weight: 600; font-variant-numeric: tabular-nums; }
  .wa-slot.busy { opacity: 0.55; }
  .wa-slot .who, .wa-slot .tag { color: #8fa6ae; font-size: 0.76rem; }
  .wa-slot.free .tag { color: #25d366; }
  .wa-booking { color: #25d366; font-weight: 600; font-size: 0.78rem; }
  /* target: booked muestra la reserva, sin booked muestra "libre" */
  .wa-slot.target:not(.booked) .wa-booking { display: none; }
  .wa-slot.target.booked .tag { display: none; }
  .wa-fly { pointer-events: none; overflow: hidden; box-shadow: 0 18px 40px rgb(0 0 0 / 0.5); }
  /* tarjeta con los datos de la reserva (estado final visible por defecto) */
  .wa-detail {
    position: absolute; left: 0.2rem; right: 0.2rem; top: 50%; transform: translateY(-50%);
    background: #1f2c33; border: 1px solid var(--line); border-radius: 0.7rem;
    padding: 0.75rem 0.85rem; box-shadow: 0 18px 40px rgb(0 0 0 / 0.5);
    display: flex; flex-direction: column; gap: 0.25rem;
  }
  .wa-detail-name { font-weight: 600; font-size: 0.86rem; display: flex; align-items: center; gap: 0.45rem; }
  .wa-detail-chip {
    font-size: 0.62rem; font-weight: 600; color: #25d366;
    border: 1px solid rgba(37, 211, 102, 0.45); border-radius: 999px; padding: 0.08rem 0.45rem;
  }
  .wa-detail-meta { font-size: 0.78rem; color: #d5dee3; }
  .wa-detail-extra { font-size: 0.68rem; color: #8fa6ae; }
</style>
