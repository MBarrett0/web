---
// Hero "Ensamblaje": isla React, animación por tiempo al cargar (no por scroll,
// no por puntero). Sin WebGL. Astro renderiza el markup en el HTML estático, así
// que el titular está en el fuente aunque el JS todavía no haya corrido.
import Hero from './hero/Hero';
---

<Hero client:load />

<noscript>
  <!-- El titular nace en contorno y se rellena con la animación. Sin JS esa
       animación nunca corre, así que quedaría en contorno para siempre: acá se
       fuerza el estado final relleno. -->
  <style>
    #inicio h1 {
      -webkit-text-stroke: 0 !important;
      color: var(--text) !important;
    }
  </style>
</noscript>
